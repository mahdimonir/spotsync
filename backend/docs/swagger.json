    "definitions": {
        "dto.CreateReservationRequest": {
            "type": "object",
            "required": [
                "license_plate",
                "zone_id"
            ],
            "properties": {
                "license_plate": {
                    "type": "string",
                    "maxLength": 15
                },
                "zone_id": {
                    "type": "integer"
                }
            }
        },
        "dto.CreateZoneRequest": {
            "type": "object",
            "required": [
                "name",
                "price_per_hour",
                "total_capacity",
                "type"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "maxLength": 100,
                    "minLength": 3
                },
                "price_per_hour": {
                    "type": "number"
                },
                "total_capacity": {
                    "type": "integer"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "general",
                        "covered",
                        "ev_charging"
                    ]
                }
            }
        },
        "dto.LoginRequest": {
            "type": "object",
            "required": [
